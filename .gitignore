# =============================================================================
# Pangolin Stack - Git Ignore
# =============================================================================

# =============================================================================
# SECRETS & CREDENTIALS
# =============================================================================
.env
.env.local
.env.*.local

# Pangolin config (contains secrets)
config/config.yml
config/pangolin/config.yml

# Traefik dynamic config (contains CrowdSec API key)
config/traefik/rules/dynamic_config.yml

# CrowdSec credentials
config/crowdsec/*_credentials.yaml
config/crowdsec/online_api_credentials.yaml
config/crowdsec/local_api_credentials.yaml

# Let's Encrypt certificates
config/letsencrypt/acme.json

# Gerbil key
config/key

# =============================================================================
# RUNTIME DATA
# =============================================================================
data/
logs/

# Traefik logs
config/traefik/logs/*.log

# CrowdSec database and logs
config/crowdsec/db/
config/crowdsec_logs/
config/crowdsec-web-ui/
config/brave/

# =============================================================================
# GEOIP DATABASES (large binary files)
# =============================================================================
config/maxmind/*.mmdb

# =============================================================================
# BACKUPS
# =============================================================================
backups/
*.tar.gz
*.backup

# =============================================================================
# GENERATED FILES
# =============================================================================
# Traefik config backups
config/traefik/*.bak.*
config/traefik/rules/*.back
config/traefik/rules/*.bak

# CrowdSec hub (auto-downloaded)
config/crowdsec/hub/
config/crowdsec/collections/
config/crowdsec/parsers/
config/crowdsec/scenarios/
config/crowdsec/postoverflows/
config/crowdsec/contexts/
config/crowdsec/appsec-configs/
config/crowdsec/appsec-rules/
config/crowdsec/patterns/
config/crowdsec/notifications/

# =============================================================================
# EDITOR & OS FILES
# =============================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Backup files
AGENTS.md.bak
*.bak

# =============================================================================
# MISC
# =============================================================================
*.log
.cursor/
__pycache__/
*.pyc
manual-upgrades/
*.bak-*

# Auto-generated by middleware-manager
config/traefik/rules/resource-overrides.yml

# Traefik static config (contains email)
config/traefik/traefik_config.yml
config/db/db.sqlite
config/db/*.sqlite.fresh
config/adguard-home/conf/AdGuardHome.yaml
pass.secret

# Real landing page (contains personal info)
sites/example-landing/

# Real landing page (contains personal info)
sites/dennisb-landing/
