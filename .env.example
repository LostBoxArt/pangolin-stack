# =============================================================================
# Pangolin Stack - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Your base domain (e.g., example.com)
BASE_DOMAIN=example.com

# =============================================================================
# PANGOLIN SECRETS
# =============================================================================
# Generate with: openssl rand -hex 32
PANGOLIN_SECRET=your_secret_here

# Admin account credentials
PANGOLIN_ADMIN_EMAIL=admin@example.com
PANGOLIN_ADMIN_PASSWORD=your_secure_password

# =============================================================================
# SMTP CONFIGURATION (for email notifications)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# =============================================================================
# CROWDSEC
# =============================================================================
# Get this key by running: docker exec crowdsec cscli bouncers add traefik-bouncer
CROWDSEC_LAPI_KEY=your_crowdsec_lapi_key
CROWDSEC_WEB_UI_PASSWORD=your_secure_password

# =============================================================================
# TRAEFIK DASHBOARD (optional - for traefik-log-dashboard addon)
# =============================================================================
# Generate with: openssl rand -hex 32
TRAEFIK_DASHBOARD_TOKEN=your_dashboard_token

# =============================================================================
# MAXMIND GEOIP (optional - for geographic analytics)
# =============================================================================
# Get a free license at: https://www.maxmind.com/en/geolite2/signup
MAXMIND_ACCOUNT_ID=your_account_id
MAXMIND_LICENSE_KEY=your_license_key

# =============================================================================
# ADGUARD HOME SYNC
# =============================================================================
# Home AdGuard Home instance (origin/master)
ADGUARD_HOME_ORIGIN_URL=http://192.168.0.1:8080
ADGUARD_HOME_ORIGIN_USERNAME=admin
ADGUARD_HOME_ORIGIN_PASSWORD=your_home_adguard_password

# VPS AdGuard Home instance (replica)
ADGUARD_VPS_USERNAME=admin
ADGUARD_VPS_PASSWORD=your_vps_adguard_password
