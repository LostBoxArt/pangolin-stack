# Pangolin Configuration
# Copy this to config.yml and fill in your values

app:
  dashboard_url: https://pangolin.YOUR_DOMAIN.xyz
  log_level: info
  save_logs: false

domains:
  domain1:
    base_domain: YOUR_DOMAIN.xyz
    cert_resolver: letsencrypt

server:
  external_port: 3000
  internal_port: 3001
  next_port: 3002
  internal_hostname: pangolin
  session_cookie_name: p_session_token
  resource_access_token_param: p_token
  resource_access_token_headers:
    id: P-Access-Token-Id
    token: P-Access-Token
  resource_session_request_param: p_session_request
  cors:
    origins:
      - https://pangolin.YOUR_DOMAIN.xyz
    methods:
      - GET
      - POST
      - PUT
      - DELETE
      - PATCH
    headers:
      - X-CSRF-Token
      - Content-Type
    credentials: false
  # Generate with: openssl rand -hex 32
  secret: YOUR_SECRET_HERE

traefik:
  cert_resolver: letsencrypt
  http_entrypoint: web
  https_entrypoint: websecure

gerbil:
  start_port: 51820
  base_endpoint: pangolin.YOUR_DOMAIN.xyz
  use_subdomain: false
  block_size: 24
  site_block_size: 30
  subnet_group: 100.64.0.0/20

rate_limits:
  global:
    window_minutes: 1
    max_requests: 500

users:
  server_admin:
    email: YOUR_EMAIL@example.com
    password: YOUR_ADMIN_PASSWORD

flags:
  require_email_verification: false
  disable_signup_without_invite: true
  disable_user_create_org: false
  allow_raw_resources: true
  allow_base_domain_resources: true

mail:
  smtp_host: smtp.example.com
  smtp_port: 465
  smtp_user: your_smtp_user
  smtp_pass: your_smtp_password
